# Ansible запускается С bastion (host-only обычно .10).
# Проверка: ssh app01 'hostname -I'  → бери IP из 192.168.56.0/24 (enp0s8).
#
# Пример этой лаборатории:
#   bastion  192.168.56.10
#   db01     192.168.56.11
#   app01    192.168.56.12

[app]
app01 ansible_host=192.168.56.12

[database]
db01 ansible_host=192.168.56.11

[servers:children]
app
database

[all:vars]
ansible_python_interpreter=/usr/bin/python3
